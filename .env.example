# Anvil Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# API Keys (at least one required)
# ============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HuggingFace token for model downloads
HF_TOKEN=hf_...

# ============================================================================
# Server Configuration
# ============================================================================
ANVIL_HOST=0.0.0.0
ANVIL_PORT=8000

# ============================================================================
# Model Configuration
# ============================================================================
DEFAULT_MODEL=local
# Options: local, shellwhisperer, gpt-4o, claude-3-5-sonnet

# ============================================================================
# Verification Settings
# ============================================================================
VERIFY_ENABLED=true
VERIFY_AUTO_RECOVER=true
VERIFY_MAX_RETRIES=3

# ============================================================================
# Memory Settings
# ============================================================================
MEMORY_ENABLED=true
MEMORY_MAX_ITEMS=1000

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# ============================================================================
# Authentication & Security (CRITICAL)
# ============================================================================
# Generate a strong secret key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ANVIL_SECRET_KEY=your-super-secret-key-change-this-in-production

# Token expiration times (in minutes/days)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================================
# OAuth2 Integration (Optional)
# ============================================================================
# GitHub OAuth2
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# Database Configuration
# ============================================================================
# SQLite (default)
DATABASE_URL=sqlite:///./anvil.db
DB_PATH=./anvil.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/anvil

# ============================================================================
# Redis Configuration (Optional - for caching and sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# WebSocket Configuration
# ============================================================================
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# Monitoring & Metrics
# ============================================================================
PROMETHEUS_ENABLED=true
METRICS_ENDPOINT=/api/metrics

# ============================================================================
# Notifications (Optional)
# ============================================================================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true
NOTIFY_ON_TASK_START=false

# ============================================================================
# Extensions
# ============================================================================
EXTENSIONS_DIR=~/.anvil/extensions
EXTENSIONS_ENABLED=true

# ============================================================================
# Debugging
# ============================================================================
DEBUG_MODE=false
DEBUG_PORT=5678

# ============================================================================
# CORS Configuration (for web UI)
# ============================================================================
CORS_ORIGINS=*
# For production, specify allowed origins:
# CORS_ORIGINS=http://localhost:3000,https://anvil.example.com

# ============================================================================
# File Storage
# ============================================================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# ============================================================================
# Session Management
# ============================================================================
SESSION_MAX_AGE_HOURS=24
SESSION_CLEANUP_INTERVAL_HOURS=1

# ============================================================================
# Performance Tuning
# ============================================================================
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT_SECONDS=300
MODEL_WARMUP=true

# ============================================================================
# Development Settings
# ============================================================================
# Set to true for development, false for production
DEVELOPMENT_MODE=false
AUTO_RELOAD=false
