# Anvil Environment Configuration
# Copy this file to .env and fill in your values

# API Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: HuggingFace token for model downloads
HF_TOKEN=hf_...

# Server Configuration
ANVIL_HOST=0.0.0.0
ANVIL_PORT=8000

# Model Configuration
DEFAULT_MODEL=local
# Options: local, shellwhisperer, gpt-4o, claude-3-5-sonnet

# Verification Settings
VERIFY_ENABLED=true
VERIFY_AUTO_RECOVER=true
VERIFY_MAX_RETRIES=3

# Memory Settings
MEMORY_ENABLED=true
MEMORY_MAX_ITEMS=1000

# Logging
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
