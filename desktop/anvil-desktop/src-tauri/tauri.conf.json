{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anvil Desktop",
  "version": "1.0.0",
  "identifier": "com.fableforge.anvil-desktop",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "echo 'Building...'"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Anvil Desktop",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "FableForge",
    "category": "DeveloperTool"
  }
}
