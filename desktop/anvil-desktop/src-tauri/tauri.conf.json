{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anvil Desktop",
  "version": "0.3.0",
  "identifier": "com.fableforge.anvil-desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:8000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Anvil Desktop - Self-Verified Coding Agent",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
